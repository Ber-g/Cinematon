# Copier en `.env` et renseigner les valeurs de votre projet Supabase.
# `.env` est gitignoré. Ces clés sont PUBLIQUES (frontend) : l'isolation des
# données est assurée par la Row-Level Security PostgreSQL, pas par le secret
# de la clé. Ne JAMAIS mettre ici la clé `service_role`.
VITE_SUPABASE_URL=https://VOTRE-PROJET.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
