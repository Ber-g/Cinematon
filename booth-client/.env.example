# Kioskoscope booth-client — config Kiosk (LOCAL, gitignoré). SANS ce fichier, la
# Kiosk tourne hors ligne (catalogue factice + sessions en mémoire).
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=xxxx
# Identité de la Kiosk — UUID RÉELS côté Supabase (table booths / organizations).
VITE_BOOTH_ID=00000000-0000-0000-0000-000000000000
VITE_ORG_ID=00000000-0000-0000-0000-000000000000
# Compte-device (membre de l'org) avec lequel la Kiosk s'authentifie à Supabase.
VITE_DEVICE_EMAIL=device@exemple.com
VITE_DEVICE_PASSWORD=change-me
# Base de l'URL de partage (QR fin de séance → /s/{token}). La page récap est servie
# par Cloudflare Pages (déploiement de share-page/). Mets ici l'URL Pages, ex.
# https://my.kioskoscope.com — ou le domaine public une fois branché.
# VITE_SHARE_BASE_URL=https://my.kioskoscope.com
