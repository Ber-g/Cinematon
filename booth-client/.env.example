# Cinematon booth-client — config cabine (LOCAL, gitignoré). SANS ce fichier, la
# cabine tourne hors ligne (catalogue factice + sessions en mémoire).
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=xxxx
# Identité de la cabine — UUID RÉELS côté Supabase (table booths / organizations).
VITE_BOOTH_ID=00000000-0000-0000-0000-000000000000
VITE_ORG_ID=00000000-0000-0000-0000-000000000000
# Compte-device (membre de l'org) avec lequel la cabine s'authentifie à Supabase.
VITE_DEVICE_EMAIL=device@exemple.com
VITE_DEVICE_PASSWORD=change-me
